# Переменные
CC = gcc # Компилятор
CFLAGS = -Wall -Wextra -std=c11 # Флаги сборки
# -Wall включает важные предупреждения
# -Wextra включает еще больше предупреждений, чем -Wall
# -std=c11 использует стандар C 2011 года
TARGET = 3tree_manager.bin # Цель, т.е. выходной файл
SRCS = main.c tree.c tree_service.c # Файлы с кодом

# Эти цели не являются файлами
.PHONY: all clean run

# Правила сборки
# Цель: зависимости

# Общее правило, зависит от цели TARGET
all: $(TARGET)

# Правило Target, зависит от SRCS
# Если какой-то файл из SRCS изменился, то нужно запустить команду
# Сравнивает дату изменения SRCS (.c файлов) и TARGET (.bin файла)
# если они новее финального, то выполнять команду, иначе готово
$(TARGET): $(SRCS)
	$(CC) $(CFLAGS) $(SRCS) -o $(TARGET)

# Правило запуска, зависит от цели all
run: all
	./$(TARGET)

# Правило очистки, не имеет зависимостей
# Удаляет файл TARGET
clean:
	rm -f $(TARGET)